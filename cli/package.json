{
  "name": "@cmdop/cli",
  "version": "0.1.1",
  "private": true,
  "description": "CMDOP CLI — standalone cross-platform binaries (not published to npm)",
  "type": "module",
  "scripts": {
    "build": "bun build --compile --minify --sourcemap ./src/main.ts --outfile dist/bin/cmdok",
    "build:all": "bun run @release/build.ts",
    "release": "bun run @release/release.ts",
    "release:fast": "bun run @release/release.ts --skip-notarize",
    "check-types": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@cmdop/node": "workspace:*",
    "@cmdop/core": "workspace:*",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@cmdop/typescript-config": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
